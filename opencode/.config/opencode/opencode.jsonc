{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3-flash-preview",
  "default_agent": "plan",
  "agent": {
    "plan": {
      "permission": {
        "external_directory": {
          "~/Syncthing/Obsidian/Personal/**": "allow"
        }
    }
  }
  },
  "plugin": ["@tarquinen/opencode-dcp@latest"],
  "mcp": {
    "duckduckgo-search": {
        "type": "local",
        "command": ["npx", "-y", "duckduckgo-mcp-server"],
        "enabled": true
    }
  }
}
