{
  "$schema": "https://opencode.ai/config.json",
  "theme": "nord",
  "model": "google/gemini-3.1-pro-preview",
  "small_model": "google/gemini-3-flash-preview",
  "default_agent": "plan",
  "mcp": {
    "duckduckgo-search": {
        "type": "local",
        "command": ["npx", "-y", "duckduckgo-mcp-server"],
        "enabled": true
    }
  }
}
